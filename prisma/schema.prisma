generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// =====================
// ENUMS
// =====================
enum Permission {
  admin
  owner
  farmmanager
  veterinarian
}

enum Gender {
  M
  F
}

enum AnimalStatus {
  active
  dead
  sold
  quarantine
  treatment
}

enum EstrusIntensity {
  weak
  normal
  strong
}

enum PregnancyStatus {
  not_started
  in_progress
  pregnant
  failed
}

enum AttemptStatus {
  in_progress
  success
  failed
}

enum MatingType {
  NATURAL
  AI
}

enum BirthType {
  normal
  assisted
  c_section
}

enum CalfStatus {
  pending
  complete
}

enum BirthSituation {
  normal
  dead
}

enum MortalitySeverity {
  mild
  moderate
  severe
}

enum UltrasoundResult {
  PREGNANT
  EMPTY
  ABSORPTION
  VIABLE
}

// =====================
// FARM
// =====================
model Farm {
  id        String   @id @default(uuid())
  name      String
  location  String
  cnpj      String?
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users               User[]
  animals             Animal[]
  pastures            Pasture[]
  estrus              Estrus[]
  pregnancies         Pregnancy[]
  births              Birth[]
  vaccinations        Vaccination[]
  managements         Management[]
  mortalities         Mortality[]
  passwordResetTokens PasswordResetToken[]
  earTagHistory       EarTagHistory[]

  @@map("farms")
}

// =====================
// USER
// =====================
model User {
  id       String @id @default(uuid())
  fullName String
  username String
  email    String @unique
  phone    String?
  password String
  role     Permission @default(veterinarian)
  active   Boolean    @default(true)

  crmv           String?
  graduationDate DateTime?
  specialties    String[]

  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  lastLogin DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  passwordResetTokens PasswordResetToken[]
  vaccinations        Vaccination[]
  ultrasounds         Ultrasound[]
  births              Birth[]
  mortalities         Mortality[]
  estrus              Estrus[]

  @@unique([farmId, username])
  @@map("users")
}

// =====================
// ANIMAL
// =====================
model Animal {
  id            String       @id @default(uuid())
  chipId        String       @unique
  currentEarTag String?
  name          String
  breed         String
  gender        Gender
  birthDate     DateTime
  status        AnimalStatus @default(active)
  deathDate     DateTime?
  origin        String       @default("born") // "born" | "purchased"

  sireId String?
  sire   Animal?  @relation("AnimalSire", fields: [sireId], references: [id])
  sireOf Animal[] @relation("AnimalSire")

  damId String?
  dam   Animal?  @relation("AnimalDam", fields: [damId], references: [id])
  damOf Animal[] @relation("AnimalDam")

 // Genealogia externa (para animais comprados ou sem registro completo)
  sireExternalName String?
  sireExternalChip String?
  damExternalName  String?
  damExternalChip  String?

  bullInAttempts Attempt[] @relation("AttemptBull")

  pastureId   String?
  pasture     Pasture? @relation(fields: [pastureId], references: [id])
  pastureName String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  earTagHistory EarTagHistory[]
  estrus        Estrus[]
  pregnancies   Pregnancy[]
  births        Birth[]
  vaccinations  Vaccination[]
  managements   Management[]
  mortalities   Mortality[]

  @@unique([farmId, chipId])
  @@map("animals")
}

// =====================
// EAR TAG HISTORY
// =====================
model EarTagHistory {
  id            String   @id @default(uuid())
  earTagNumber  String
  placementDate DateTime
  removalDate   DateTime?
  reason        String?
  createdAt     DateTime @default(now())

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("ear_tag_history")
}

// =====================
// PASTURE
// =====================
model Pasture {
  id             String   @id @default(uuid())
  name           String
  hectares       Float
  type           String
  animalCapacity Int
  currentAnimals Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animals Animal[]

  @@unique([farmId, name])
  @@map("pastures")
}

// =====================
// ESTRUS = CIO
// =====================
model Estrus {
  id         String           @id @default(uuid())
  date       DateTime
  intensity  EstrusIntensity
  nextEstrus DateTime
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  detectedById String?
  detectedBy   User? @relation(fields: [detectedById], references: [id])

  @@map("estrus")
}

// =====================
// PREGNANCY
// =====================
model Pregnancy {
  id                String          @id @default(uuid())
  currentStatus     PregnancyStatus @default(not_started)
  currentStatusDate DateTime        @default(now())
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  attempts Attempt[]

  @@map("pregnancies")
}

// =====================
// ATTEMPT
// =====================
model Attempt {
  id                 String        @id @default(uuid())
  number             Int
  matingDate         DateTime
  matingType         MatingType
  semenName          String?
  technician         String?
  estimatedBirthDate DateTime
  attemptStatus      AttemptStatus @default(in_progress)
  notes              String?
  createdAt          DateTime      @default(now())

  bullId String?
  bull   Animal? @relation("AttemptBull", fields: [bullId], references: [id])

  pregnancyId String
  pregnancy   Pregnancy @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)

  ultrasounds Ultrasound[]
  births      Birth[]

  @@map("attempts")
}

// =====================
// ULTRASOUND
// =====================
model Ultrasound {
  id             String           @id @default(uuid())
  days           Int
  result         UltrasoundResult
  notes          String?
  ultrasoundDate DateTime @default(now())
  createdAt      DateTime @default(now())

  attemptId String
  attempt   Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  veterinarianId String?
  veterinarian   User? @relation(fields: [veterinarianId], references: [id])

  @@map("ultrasounds")
}

// =====================
// BIRTH
// =====================
model Birth {
  id          String         @id @default(uuid())
  birthDate   DateTime
  birthTime   String?
  birthType   BirthType
  calfGender  Gender?
  calfWeight  Float?
  calfEarTag  String?
  calfChip    String?
  calfStatus  CalfStatus     @default(pending)
  situation   BirthSituation @default(normal)
  deathReason String?
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  damId String
  dam   Animal @relation(fields: [damId], references: [id])

  attemptId String?
  attempt   Attempt? @relation(fields: [attemptId], references: [id])

  veterinarianId String?
  veterinarian   User? @relation(fields: [veterinarianId], references: [id])

  mortalities Mortality[]

  @@map("births")
}

// =====================
// VACCINATION
// =====================
model Vaccination {
  id              String   @id @default(uuid())
  vaccineType     String
  brand           String
  batch           String
  vaccinationDate DateTime
  expirationDate  DateTime
  nextDoseDate    DateTime?
  photoUrl        String?
  reaction        String?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  veterinarianId String?
  veterinarian   User? @relation(fields: [veterinarianId], references: [id])

  @@map("vaccinations")
}

// =====================
// MANAGEMENT
// =====================
model Management {
  id                 String   @id @default(uuid())
  originPasture      String
  destinationPasture String
  movementDate       DateTime
  reason             String
  employee           String
  batchId            String?
  batchTotal         Int?
  createdAt          DateTime @default(now())

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("managements")
}

// =====================
// MORTALITY
// =====================
model Mortality {
  id            String            @id @default(uuid())
  deathDate     DateTime
  deathTime     String?
  deathLocation String
  causeOfDeath  String
  severity      MortalitySeverity?
  necropsy      Boolean @default(false)
  disposal      String?
  photos        String[]
  origin        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  birthId String?
  birth   Birth? @relation(fields: [birthId], references: [id])

  registeredById String?
  registeredBy   User? @relation(fields: [registeredById], references: [id])

  @@map("mortalities")
}

// =====================
// PASSWORD RESET
// =====================
model PasswordResetToken {
  id        String   @id @default(uuid())
  code      String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  farmId String
  farm   Farm @relation(fields: [farmId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_reset_tokens")
}
