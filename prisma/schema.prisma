// ========================================
// SCHEMA PRISMA - app_pecuaria
// ========================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
} 

// ========================================
// MODELO: FAZENDA (Herd)
// ========================================

model Fazenda {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  nome              String
  localizacao       String
  cnpj              String?
  logoUrl           String?
  
  ativo             Boolean  @default(true)
  criadoEm          DateTime @default(now())
  atualizadoEm      DateTime @updatedAt

  // Relacionamentos
  usuarios          Usuario[]
  animais           Animal[]
  pastos            Pasto[]
  
  @@map("fazendas")
}

// ========================================
// MODELO: USUÁRIO
// ========================================

model Usuario {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Dados pessoais
  nomeCompleto        String
  email               String   @unique
  telefone            String?
  
  // Autenticação
  senha               String
  role                Permissao @default(veterinario)
  ativo               Boolean  @default(true)
  
  // Dados profissionais (para veterinários)
  crv                 String?  // CRV obrigatório para vet
  crmv                String?  // Conselho Regional Medicina Veterinária
  dataFormatura       DateTime?
  especialidades      String[] // ["Reprodução", "Obstetrícia"]
  
  // Reset de senha
  tokenResetSenha     String?
  expiracaoResetSenha DateTime?
  
  // Relacionamento
  fazendaId           String   @db.ObjectId
  fazenda             Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  
  // Auditoria
  ultimoLogin         DateTime?
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@unique([fazendaId, email])
  @@map("usuarios")
}

// ========================================
// ENUM: PERMISSÕES (Roles)
// ========================================
enum Permissao {
  admin
  owner
  farmmanager
  veterinario
}

// ========================================
// MODELO: ANIMAL
// ========================================
model Animal {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  // Identificação
  chipId              String   @unique
  brincoAtual         String?  @unique
  historicoBrincos    HistoricoBrinco[]
  
  // Dados básicos
  nome                String
  raca                String
  sexo                String   // "M" ou "F"
  dataNascimento      DateTime
  
  // Genealogia
  paiId               String?  @db.ObjectId
  maeId               String?  @db.ObjectId
  
  // Localização
  pastoId             String?  @db.ObjectId
  pastoNome           String?
  
  // Status
  status              String   @default("ativo") // "ativo", "morto", "vendido"
  dataMorte           DateTime?
  
  // Relacionamento
  fazendaId           String   @db.ObjectId
  fazenda             Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  
  // Auditoria
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@unique([fazendaId, chipId])
  @@map("animais")
}

// ========================================
// MODELO: HISTÓRICO DE BRINCOS
// ========================================
model HistoricoBrinco {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  numeroBrinco        String
  animalId            String   @db.ObjectId
  animal              Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  dataColocacao       DateTime
  dataRemocao         DateTime?
  motivo              String?
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())

  @@map("historico_brincos")
}

// ========================================
// MODELO: PASTO
// ========================================
model Pasto {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  nome                String
  hectares            Float
  tipo                String   // "nativa", "plantada", "irrigada", "confinamento", "quarentena"
  capacidadeAnimais   Int
  animaisAtuais       Int      @default(0)
  ativo               Boolean  @default(true)
  
  fazendaId           String   @db.ObjectId
  fazenda             Fazenda  @relation(fields: [fazendaId], references: [id], onDelete: Cascade)
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@unique([fazendaId, nome])
  @@map("pastos")
}

// ========================================
// MODELO: CIO
// ========================================
model CIO {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  animalId            String   @db.ObjectId
  data                DateTime
  intensidade         String   // "Fraco", "Normal", "Forte"
  detectadoPor        String
  proximoCio          DateTime // Auto-calculado (data + 21 dias)
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("cios")
}

// ========================================
// MODELO: PRENHEZ
// ========================================
model Prenhez {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  animalId            String   @db.ObjectId
  tentativas          Tentativa[]
  
  statusAtual         String   @default("nao_iniciada") // "nao_iniciada", "prenha", "vazia", "absorcao"
  dataStatusAtual     DateTime @default(now())
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("prenhezes")
}

// ========================================
// MODELO: TENTATIVA DE PRENHEZ
// ========================================
model Tentativa {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  numero              Int
  prenhezId           String   @db.ObjectId
  prenhez             Prenhez  @relation(fields: [prenhezId], references: [id], onDelete: Cascade)
  
  // Cobertura
  dataCobertura       DateTime
  tipoCobertura       String   // "MONTA", "INSEMINACAO"
  touroId             String?  @db.ObjectId
  nomeSemen           String?
  tecnico             String?
  dataPartoEstimada   DateTime // Auto-calculado (data + 283 dias)
  
  // Ultrassons (relacionamentos via model Ultrassom)
  ultrassons          Ultrassom[]
  
  // Parto
  partoId             String?  @db.ObjectId
  
  statusTentativa     String   @default("em_andamento") // "em_andamento", "sucesso", "falha"
  observacoes         String?
  
  criadoEm            DateTime @default(now())

  @@map("tentativas")
}

// ========================================
// MODELO: ULTRASSOM
// ========================================
model Ultrassom {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  tentativaId         String   @db.ObjectId
  tentativa           Tentativa @relation(fields: [tentativaId], references: [id], onDelete: Cascade)
  
  dias                Int      // 30, 60, 260
  resultado           String   // "PRENHA", "VAZIA", "ABSORCAO", "VIAVEL"
  observacoes         String?
  veterinarioId       String?  @db.ObjectId
  
  dataUltrassom       DateTime @default(now())

  @@map("ultrassons")
}

// ========================================
// MODELO: PARTO/NASCIMENTO
// ========================================
model Parto {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  maeId               String   @db.ObjectId
  prenhezId           String?  @db.ObjectId
  
  dataParto           DateTime
  horaParto           String?
  
  // Tipo de nascimento
  tipoNascimento      String   // "normal", "ajuda", "cesaria"
  
  // Veterinário que atendeu
  veterinarioId       String?  @db.ObjectId
  veterinarioNome     String?
  veterinarioCrv      String?
  
  // Bezerro
  sexoBezerro         String?  // "M", "F"
  pesoBezerro         Float?
  brincoBezerro       String?
  chipBezerro         String?
  statusBezerro       String   @default("pendente") // "pendente", "completo"
  
  // Óbito
  situacao            String   @default("normal") // "normal", "obito"
  motivoObito         String?
  
  observacoes         String?
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("partos")
}

// ========================================
// MODELO: VACINAÇÃO
// ========================================
model Vacinacao {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  animalId            String   @db.ObjectId
  
  tipoVacina          String   // "Raiva", "Febre Aftosa", etc
  marca               String
  lote                String
  
  dataVacinacao       DateTime
  dataValidade        DateTime
  proximaDose          DateTime?
  
  fotoUrl             String?
  reacao              String?  // Reações adversas
  veterinarioId       String?  @db.ObjectId
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("vacinacoes")
}

// ========================================
// MODELO: MANEJO (Movimentação)
// ========================================
model Manejo {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  animalId            String   @db.ObjectId
  
  pastoOrigem         String
  pastoDestino        String
  dataMovimentacao    DateTime
  motivo              String   // "Rotação normal", "Manejo reprodutivo", etc
  
  funcionario         String   // Nome de quem fez
  batchId             String?  // Para movimentações em lote
  totalDoLote         Int?
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())

  @@map("manejos")
}

// ========================================
// MODELO: MORTALIDADE
// ========================================
model Mortalidade {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  animalId            String   @db.ObjectId
  
  dataMorte           DateTime
  horaMorte           String?
  localMorte          String   // Nome do pasto ou local
  
  causaMorte          String
  gravidade           String?  // "Leve", "Moderada", "Severa"
  
  necropsia           Boolean  @default(false)
  descarte            String?
  
  fotos               String[] // URLs das fotos
  
  origem              String?  // "parto", "manejo", "doença"
  partoId             String?  @db.ObjectId
  
  observacoes         String?
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())
  atualizadoEm        DateTime @updatedAt

  @@map("mortalidades")
}

// ========================================
// MODELO: TOKEN DE RESET SENHA
// ========================================
model TokenResetSenha {
  id                  String   @id @default(auto()) @map("_id") @db.ObjectId
  
  usuarioId           String   @db.ObjectId
  codigo              String   @unique
  expiresAt           DateTime
  usado               Boolean  @default(false)
  
  fazendaId           String   @db.ObjectId
  
  criadoEm            DateTime @default(now())

  @@map("tokens_reset_senha")
}