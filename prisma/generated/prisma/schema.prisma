generator client {
  provider = "prisma-client-js"
  output   = "./generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ========================================
// MODEL: FARM
// ========================================
model Farm {
  id        String   @id @default(uuid())
  name      String
  location  String
  cnpj      String?
  logoUrl   String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users    User[]
  animals  Animal[]
  pastures Pasture[]

  @@map("farms")
}

// ========================================
// MODEL: USER
// ========================================
model User {
  id                   String     @id @default(uuid())
  fullName             String
  email                String
  phone                String?
  password             String
  role                 Permission @default(veterinarian)
  active               Boolean    @default(true)
  crv                  String?
  crmv                 String?
  graduationDate       DateTime?
  specialties          String[]
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  lastLogin            DateTime?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, email])
  @@map("users")
}

// ========================================
// ENUM: ROLES
// ========================================
enum Permission {
  admin
  owner
  farmmanager
  veterinarian
}

// ========================================
// MODEL: ANIMAL
// ========================================
model Animal {
  id            String    @id @default(uuid())
  chipId        String    @unique
  currentEarTag String?   @unique
  name          String
  breed         String
  gender        String
  birthDate     DateTime
  sireId        String?
  damId         String?
  pastureId     String?
  pastureName   String?
  status        String    @default("active")
  deathDate     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  farmId        String
  farm          Farm            @relation(fields: [farmId], references: [id], onDelete: Cascade)
  earTagHistory EarTagHistory[]

  @@unique([farmId, chipId])
  @@map("animals")
}

// ========================================
// MODEL: EAR TAG HISTORY
// ========================================
model EarTagHistory {
  id            String    @id @default(uuid())
  earTagNumber  String
  placementDate DateTime
  removalDate   DateTime?
  reason        String?
  createdAt     DateTime  @default(now())

  farmId   String
  animalId String
  animal   Animal @relation(fields: [animalId], references: [id], onDelete: Cascade)

  @@map("ear_tag_history")
}

// ========================================
// MODEL: PASTURE
// ========================================
model Pasture {
  id             String   @id @default(uuid())
  name           String
  hectares       Float
  type           String
  animalCapacity Int
  currentAnimals Int      @default(0)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  farmId String
  farm   Farm   @relation(fields: [farmId], references: [id], onDelete: Cascade)

  @@unique([farmId, name])
  @@map("pastures")
}

// ========================================
// MODEL: ESTRUS (Heat/CIO)
// ========================================
model Estrus {
  id         String   @id @default(uuid())
  animalId   String
  date       DateTime
  intensity  String
  detectedBy String
  nextEstrus DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  farmId String

  @@map("estrus")
}

// ========================================
// MODEL: PREGNANCY
// ========================================
model Pregnancy {
  id                String   @id @default(uuid())
  animalId          String
  currentStatus     String   @default("not_started")
  currentStatusDate DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  farmId   String
  attempts Attempt[]

  @@map("pregnancies")
}

// ========================================
// MODEL: ATTEMPT
// ========================================
model Attempt {
  id                 String   @id @default(uuid())
  number             Int
  matingDate         DateTime
  matingType         String
  bullId             String?
  semenName          String?
  technician         String?
  estimatedBirthDate DateTime
  birthId            String?
  attemptStatus      String   @default("in_progress")
  notes              String?
  createdAt          DateTime @default(now())

  pregnancyId String
  pregnancy   Pregnancy    @relation(fields: [pregnancyId], references: [id], onDelete: Cascade)
  ultrasounds Ultrasound[]

  @@map("attempts")
}

// ========================================
// MODEL: ULTRASOUND
// ========================================
model Ultrasound {
  id             String   @id @default(uuid())
  days           Int
  result         String
  notes          String?
  veterinarianId String?
  ultrasoundDate DateTime @default(now())

  attemptId String
  attempt   Attempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)

  @@map("ultrasounds")
}

// ========================================
// MODEL: BIRTH
// ========================================
model Birth {
  id               String   @id @default(uuid())
  damId            String
  pregnancyId      String?
  birthDate        DateTime
  birthTime        String?
  birthType        String
  veterinarianId   String?
  veterinarianName String?
  veterinarianCrv  String?
  calfGender       String?
  calfWeight       Float?
  calfEarTag       String?
  calfChip         String?
  calfStatus       String   @default("pending")
  situation        String   @default("normal")
  deathReason      String?
  notes            String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  farmId String

  @@map("births")
}

// ========================================
// MODEL: VACCINATION
// ========================================
model Vaccination {
  id              String    @id @default(uuid())
  animalId        String
  vaccineType     String
  brand           String
  batch           String
  vaccinationDate DateTime
  expirationDate  DateTime
  nextDoseDate    DateTime?
  photoUrl        String?
  reaction        String?
  veterinarianId  String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  farmId String

  @@map("vaccinations")
}

// ========================================
// MODEL: MANAGEMENT (Movement)
// ========================================
model Management {
  id                 String   @id @default(uuid())
  animalId           String
  originPasture      String
  destinationPasture String
  movementDate       DateTime
  reason             String
  employee           String
  batchId            String?
  batchTotal         Int?
  createdAt          DateTime @default(now())

  farmId String

  @@map("managements")
}

// ========================================
// MODEL: MORTALITY
// ========================================
model Mortality {
  id            String   @id @default(uuid())
  animalId      String
  deathDate     DateTime
  deathTime     String?
  deathLocation String
  causeOfDeath  String
  severity      String?
  necropsy      Boolean  @default(false)
  disposal      String?
  photos        String[]
  origin        String?
  birthId       String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  farmId String

  @@map("mortalities")
}

// ========================================
// MODEL: PASSWORD RESET TOKEN
// ========================================
model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  code      String   @unique
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  farmId String

  @@map("password_reset_tokens")
}
